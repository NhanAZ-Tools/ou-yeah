{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "types": [
      "chrome"
    ],
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "src/**/*.js"
  ]
}
